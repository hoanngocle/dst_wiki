r></tbody></table>\n<table><tbody><tr><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Glow_Berry\" title=\"Glow Berry\"><img alt=\"Glow Berry.png\" src=\"https://dontstarve.wiki.gg/images/Glow_Berry.png?8b8a71\" width=\"64\" height=\"64\"></a></div></div></td><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Durian\" title=\"Durian\"><img alt=\"Durian.png\" src=\"https://dontstarve.wiki.gg/images/Durian.png?569b17\" width=\"64\" height=\"64\"></a></div></div></td><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Durian\" title=\"Durian\"><img alt=\"Durian.png\" src=\"https://dontstarve.wiki.gg/images/Durian.png?569b17\" width=\"64\" height=\"64\"></a></div></div></td><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Durian\" title=\"Durian\"><img alt=\"Durian.png\" src=\"https://dontstarve.wiki.gg/images/Durian.png?569b17\" width=\"64\" height=\"64\"></a></div></div></td><td><a href=\"https://dontstarve.wiki.gg/wiki/Portable_Crock_Pot\" title=\"Portable Crock Pot\"><img alt=\"Portable Crock Pot.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Portable_Crock_Pot.png/42px-Portable_Crock_Pot.png?f4c0d3\" width=\"42\" height=\"42\"></a></td><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Glow_Berry_Mousse\" title=\"Glow Berry Mousse\"><img alt=\"Glow Berry Mousse.png\" src=\"https://dontstarve.wiki.gg/images/Glow_Berry_Mousse.png?c69fa4\" width=\"64\" height=\"64\"></a></div></div></td><td>50% chance of producing <a href=\"https://dontstarve.wiki.gg/wiki/Monster_Tartare\" title=\"Monster Tartare\">Monster Tartare</a></td></tr></tbody></table>\n<div></div>\n<h2><span class=\"mw-headline\" id=\"Gallery\"><a href=\"https://dontstarve.wiki.gg/wiki/Blueprint\" title=\"Blueprint\"><img alt=\"Blueprint.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Blueprint.png/32px-Blueprint.png?80b6b5\" width=\"32\" height=\"32\"></a> Gallery</span></h2>\n<ul class=\"gallery mw-gallery-traditional\">\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/File:Glow_Berry_Mousse_128x128.png\" class=\"image\" title=\"Icon used as emoji for Official Klei Discord.\"><img alt=\"Icon used as emoji for Official Klei Discord.\" src=\"https://dontstarve.wiki.gg/images/thumb/Glow_Berry_Mousse_128x128.png/120px-Glow_Berry_Mousse_128x128.png?e327b4\" width=\"120\" height=\"120\"></a></div></div>\n\t\t\t<div class=\"gallerytext\">Icon used as emoji for Official Klei Discord.</div>\n\t\t</div></li>\n</ul>\n<div class=\"tabber tabber--init\"><a class=\"tabber__tab\" id=\"By_Type-0-label\" href=\"https://dontstarve.wiki.gg/wiki/Glow_Berry_Mousse#By_Type-0\">By Type</a><a class=\"tabber__tab\" id=\"By_Crock_Pot_Value-0-label\" href=\"https://dontstarve.wiki.gg/wiki/Glow_Berry_Mousse#By_Crock_Pot_Value-0\">By Crock Pot Value</a><section class=\"tabber__section\"><p class=\"mw-empty-elt\"></p>\n<p class=\"mw-empty-elt\"></p><p class=\"mw-empty-elt\"></p>\n<p class=\"mw-empty-elt\"></p></section></div>\n\n\n\n\n</div>",
