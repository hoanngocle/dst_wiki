2\n|item3 = Palm Leaf\n|count3 = 4\n|tool = Science Machine\n|result = Thatch Sail}}\n{{Recipe\n|item1 = Vine\n|count1 = 2\n|item2 = Cloth\n|count2 = 2\n|item3 = Empty Bottle\n|count3 = 3\n|tool = Science Machine\n|result = Life Jacket}}\n{{Recipe\n|item1 = Vine\n|item2 = Bamboo\n|count2 = 2\n|item3 = Seaweed\n|tool = Science Machine\n|result = Mussel Stick}}\n{{Recipe\n|item1 = Vine\n|count1 = 2\n|item2 = Snakeskin\n|count2 = 2\n|item3 = Bone Shards\n|count3 = 2\n|tool = Science Machine\n|result = Snakeskin Jacket}}\n{{Recipe\n|item1 = Vine\n|count1 = 2\n|item2 = Shark Fin\n|item3 = Coconut\n|tool = Science Machine\n|result = Sleek Hat}}\n{{Recipe\n|item2 = Seaweed\n|count2 = 5\n|item1 = Vine\n|count1 = 2\n|item3 = Shark Gills\n|tool = Alchemy Engine\n|result = Sea Sack}}\n{{Recipe\n|item2 = Cloth\n|item1 = Vine\n|count1 = 3\n|item3 = Cork\n|count3 = 6\n|tool = Alchemy Engine\n|result = Pith Hat\n|dlc = Hamlet}}\n{{Resources}}\n\n[[pl:Winorośl (DSS)]]\n[[vi:Cành Leo]]\n[[Category:Items]]\n[[Category:Flammable Objects]]\n[[Category:Resources]]\n[[Category:Fuel]]\n[[Category:Mob Dropped Items]]"
