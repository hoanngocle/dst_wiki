d></tr></tbody></table>\n<h2><span class=\"mw-headline\" id=\"Usage\"><a href=\"https://dontstarve.wiki.gg/wiki/Icon_Tools\" title=\"Icon Tools\"><img alt=\"Icon Tools.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Icon_Tools.png/32px-Icon_Tools.png?f672d4\" width=\"32\" height=\"39\"></a> Usage</span></h2>\n<table><tbody><tr><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Butter_Muffin\" title=\"Butter Muffin\"><img alt=\"Butter Muffin.png\" src=\"https://dontstarve.wiki.gg/images/Butter_Muffin.png?c6184a\" width=\"64\" height=\"64\"></a></div></div></td><td><a href=\"https://dontstarve.wiki.gg/wiki/Pig_Icon\" title=\"Pig Icon\"><img alt=\"Pig Icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Pig_Icon.png/42px-Pig_Icon.png?2561d3\" width=\"42\" height=\"42\"></a></td><td><div class=\"icon-frame\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Manure\" title=\"Manure\"><img alt=\"Manure.png\" src=\"https://dontstarve.wiki.gg/images/Manure.png?f3cf48\" width=\"64\" height=\"64\"></a></div></div></td></tr></tbody></table>\n<h2><span class=\"mw-headline\" id=\"Gallery\"><a href=\"https://dontstarve.wiki.gg/wiki/Blueprint\" title=\"Blueprint\"><img alt=\"Blueprint.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Blueprint.png/32px-Blueprint.png?80b6b5\" width=\"32\" height=\"32\"></a> Gallery</span></h2>\n<ul class=\"gallery mw-gallery-traditional\">\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/File:CD_butterflymuffin.png\" class=\"image\" title=\"Original HD icon from Bonus Materials from CD Don&#x27;t Starve.\"><img alt=\"Original HD icon from Bonus Materials from CD Don&#x27;t Starve.\" src=\"https://dontstarve.wiki.gg/images/thumb/CD_butterflymuffin.png/120px-CD_butterflymuffin.png?7654fe\" width=\"120\" height=\"120\"></a></div></div>\n\t\t\t<div class=\"gallerytext\">Original HD icon from Bonus Materials from <a href=\"https://dontstarve.wiki.gg/wiki/CD_Don%27t_Starve\" title=\"CD Don&#x27;t Starve\">CD Don&#x27;t Starve</a>.</div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/File:Butter_Muffin_128x128.png\" class=\"image\" title=\"Icon used as emoji for Official Klei Discord\"><img alt=\"Icon used as emoji for Official Klei Discord\" src=\"https://dontstarve.wiki.gg/images/thumb/Butter_Muffin_128x128.png/120px-Butter_Muffin_128x128.png?ed437e\" width=\"120\" height=\"120\"></a></div></div>\n\t\t\t<div class=\"gallerytext\">Icon used as emoji for Official Klei Discord</div>\n\t\t</div></li>\n</ul>\n<div class=\"tabber tabber--init\"><a class=\"tabber__tab\" id=\"By_Type-0-label\" href=\"https://dontstarve.wiki.gg/wiki/Butter_Muffin#By_Type-0\">By Type</a><a class=\"tabber__tab\" id=\"By_Crock_Pot_Value-0-label\" href=\"https://dontstarve.wiki.gg/wiki/Butter_Muffin#By_Crock_Pot_Value-0\">By Crock Pot Value</a><section class=\"tabber__section\"><p class=\"mw-empty-elt\"></p>\n<p class=\"mw-empty-elt\"></p><p class=\"mw-empty-elt\"></p>\n<p class=\"mw-empty-elt\"></p></section></div>\n\n\n\n\n</div>",
