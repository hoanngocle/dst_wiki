png/20px-Wigfrid_Portrait.png?a0e6fa\" width=\"20\" height=\"20\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Battle_Helm\" title=\"Battle Helm\"><img alt=\"Battle Helm\" src=\"https://dontstarve.wiki.gg/images/Battle_Helm.png?dc32f5\" width=\"78\" height=\"78\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Battle_Helm\" title=\"Battle Helm\">Battle Helm</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Reign_of_Giants\" title=\"Reign of Giants\"><img alt=\"Reign of Giants icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Reign_of_Giants_icon.png/20px-Reign_of_Giants_icon.png?12c8d5\" width=\"20\" height=\"22\"></a><a href=\"https://dontstarve.wiki.gg/wiki/Wigfrid\" title=\"Wigfrid\"><img alt=\"Wigfrid Portrait.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Wigfrid_Portrait.png/20px-Wigfrid_Portrait.png?a0e6fa\" width=\"20\" height=\"20\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Poison_Spear\" title=\"Poison Spear\"><img alt=\"Poison Spear\" src=\"https://dontstarve.wiki.gg/images/Poison_Spear.png?ab1958\" width=\"78\" height=\"78\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Poison_Spear\" title=\"Poison Spear\">Poison Spear</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Seashell_Suit\" title=\"Seashell Suit\"><img alt=\"Seashell Suit\" src=\"https://dontstarve.wiki.gg/images/Seashell_Suit.png?c649c8\" width=\"78\" height=\"78\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Seashell_Suit\" title=\"Seashell Suit\">Seashell Suit</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Limestone_Suit\" title=\"Limestone Suit\"><img alt=\"Limestone Suit\" src=\"https://dontstarve.wiki.gg/images/Limestone_Suit.png?853f92\" width=\"78\" height=\"78\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Limestone_Suit\" title=\"Limestone Suit\">Limestone Suit</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Cactus_Armor\" title=\"Cactus Armor\"><img alt=\"Cactus Armor\" src=\"https://dontstarve.wiki.gg/images/Cactus_Armor.png?5578b4\" width=\"78\" height=\"78\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Cactus_Armor\" title=\"Cactus Armor\">Cactus Armor</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Horned_Helmet\" title=\"Horned Helmet\"><img alt=\"Horned Helmet\" src=\"https://don