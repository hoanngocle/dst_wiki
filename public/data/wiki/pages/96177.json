ht=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Tar_Lamp\" title=\"Tar Lamp\"><img alt=\"Tar Lamp\" src=\"https://dontstarve.wiki.gg/images/Tar_Lamp.png?660ea0\" width=\"70\" height=\"70\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Tar_Lamp\" title=\"Tar Lamp\">Tar Lamp</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Obsidian_Fire_Pit\" title=\"Obsidian Fire Pit\"><img alt=\"Obsidian Fire Pit\" src=\"https://dontstarve.wiki.gg/images/Obsidian_Fire_Pit.png?b50b43\" width=\"70\" height=\"70\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Obsidian_Fire_Pit\" title=\"Obsidian Fire Pit\">Obsidian Fire Pit</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/images/thumb/Shipwrecked_icon.png/20px-Shipwrecked_icon.png?3f6ffb\" width=\"20\" height=\"22\"></a></div>\n\t\t</div></li>\n\t\t<li class=\"gallerybox\"><div>\n\t\t\t<div class=\"thumb\"><div><a href=\"https://dontstarve.wiki.gg/wiki/Bottle_Lantern\" title=\"Bottle Lantern\"><img alt=\"Bottle Lantern\" src=\"https://dontstarve.wiki.gg/images/Bottle_Lantern.png?850ffa\" width=\"70\" height=\"70\"></a></div></div>\n\t\t\t<div class=\"gallerytext\"><a href=\"https://dontstarve.wiki.gg/wiki/Bottle_Lantern\" title=\"Bottle Lantern\">Bottle Lantern</a><br><a href=\"https://dontstarve.wiki.gg/wiki/Shipwrecked\" title=\"Shipwrecked\"><img alt=\"Shipwrecked icon.png\" src=\"https://dontstarve.wiki.gg/i